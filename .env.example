# ---------------------------------------------------------------------------
# GEOTECH 3D / GEOSPATIAL HUB — frontend environment
# Copy this file to `.env.local` and fill in your Supabase project values.
# Both are PUBLIC (safe to ship to the browser). Get them in the Supabase
# dashboard under: Project Settings → API.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ---------------------------------------------------------------------------
# Used ONLY by `npm run seed` (server-side, on your machine). NEVER put the
# service_role key in .env.local or anything shipped to the browser.
# Set these as shell env vars when seeding instead of committing them:
#   $env:SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
#   $env:SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"
# ---------------------------------------------------------------------------
